{
  "version": "0.2.0",
  "configurations": [
	{
	  "name": "all/unit-test",
	  "type": "lldb-dap",
	  "request": "launch",
	  "program": "${workspaceFolder}/build/clang/debug/tests/unit_tests_all",
	  "stopAtEntry": false,
	  "cwd": "${workspaceFolder}",
	  "environment": [],
	  "externalConsole": true,
	  "MIMode": "lldb"
	},
	{
	  "name": "media/transcoder",
	  "type": "lldb-dap",
	  "request": "launch",
	  "program": "${workspaceFolder}/build/clang/debug/src/media/samples/sample_transcoder",
	  "args": [
		"${input:videoPath}"
	  ],
	  "stopAtEntry": false,
	  "cwd": "${workspaceFolder}",
	  "externalConsole": false,
	  "MIMode": "lldb"
	},
	{
	  "name": "recog/face_detect",
	  "type": "lldb-dap",
	  "request": "launch",
	  "program": "${workspaceFolder}/build/clang/debug/src/recog/apps/face_detect/face_detector",
	  "args": [
		"tests/data/face_detectors/faces.jpg", "--model", "tests/data/face_detectors/blazefaces-320.onnx"
	  ],
	  "stopAtEntry": false,
	  "cwd": "${workspaceFolder}",
	  "externalConsole": false,
	  "MIMode": "lldb"
	}
	
  ]
}
