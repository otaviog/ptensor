{
  "name": "ptensor-js",
  "version": "1.0.0",
  "description": "PTensor bindings for TypeScript",
  "type": "module",
  "main": "./build/ptensor-wrapper.js",
  "types": "./build/ptensor-wrapper.d.ts",
  "scripts": {
    "build": "bun build",
    "clean": "rm -rf build",
    "test": "bun test src/ptensor/__tests__/tensor.test.ts",
    "test:wasm": "bun test src/ptensor/backends/wasm/__tests__/wasm.test.ts",
    "test:integration": "bun test src/ptensor/__tests__/tensor.integration.test.ts src/ptensor/__tests__/infer.integration.test.ts",
    "test:all": "bun test"
  },
  "keywords": [
    "tensor",
    "wasm",
    "webassembly",
    "numerical",
    "ai"
  ],
  "author": "Otavio Gomes",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/emscripten": "^1.39.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "private": true
}
