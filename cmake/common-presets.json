{
    "version": 6,
    "configurePresets": [
        {
            "name": "hidden/base",
            "description": "Base for all configs",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "SKBUILD_PROJECT_NAME": "ptensor"
            }
        },
        {
            "name": "hidden/base-dev",
            "inherits": "hidden/base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/triplets",
              "VCPKG_MANIFEST_FEATURES": "tests;samples;io;op;infer;media;viz",
                "WITH_IO": "ON",
                "WITH_OP": "ON",
       			"WITH_INFER": "ON",
                "WITH_RECOG": "ON",
                "WITH_MEDIA": "ON",
                "WITH_VIZ": "ON",
              "BUILD_TESTS": "ON",
			  "BUILD_APPS": "ON"
            }
        },
        {
            "inherits": "hidden/base",
            "name": "package-core"
        },
        {
            "inherits": "hidden/base",
            "name": "package-dependencies",
            "cacheVariables": {
                "WITH_IO": "ON",
                "WITH_OP": "ON"
            }
        }
    ]
}
